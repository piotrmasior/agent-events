B) Replace the existing `renderTasks(tasks)` function with this state-driven machinery. Add it to the <script> section:

```javascript
var taskState = { all: [], filtered: [], search: "", statusFilter: "", targetFilter: "", projectFilter: "", sortKey: "task_updated_at", sortDesc: true };

function populateFilterDropdown(id, values) {
  var sel = document.getElementById(id);
  var current = sel.value;
  var firstLabel = sel.options[0].text;
  var opts = ['<option value="">' + firstLabel + '</option>'];
  values.forEach(function(v){ opts.push('<option value="' + v + '">' + v + '</option>'); });
  sel.innerHTML = opts.join('');
  if (Array.from(sel.options).some(function(o){return o.value===current})) sel.value = current;
}

function applyTaskFilters() {
  var q = taskState.search.trim().toLowerCase();
  var sf = taskState.statusFilter, tf = taskState.targetFilter, pf = taskState.projectFilter;
  taskState.filtered = taskState.all.filter(function(t){
    if (sf && (t.task_status || 'pending').toLowerCase() !== sf) return false;
    if (tf && (t.task_target || '') !== tf) return false;
    if (pf && (t.project || '') !== pf) return false;
    if (q) {
      var hay = ((t.detail || '') + ' ' + (t.project || '') + ' ' + (t.task_target || '') + ' ' + (t.task_id || '')).toLowerCase();
      if (hay.indexOf(q) === -1) return false;
    }
    return true;
  });
  var k = taskState.sortKey, desc = taskState.sortDesc;
  taskState.filtered.sort(function(a,b){
    var av = (a[k] || '').toString(), bv = (b[k] || '').toString();
    return desc ? (av < bv ? 1 : av > bv ? -1 : 0) : (av < bv ? -1 : av > bv ? 1 : 0);
  });
  renderTasks();
}

function renderTasks() {
  var el = document.getElementById('taskTable');
  var count = document.getElementById('taskCount');
  count.textContent = '(' + taskState.filtered.length + ' of ' + taskState.all.length + ')';
  if (taskState.filtered.length === 0) { el.innerHTML = '<div class="empty">No matching tasks</div>'; return; }
  function th(key, label) {
    var arrow = taskState.sortKey === key ? (taskState.sortDesc ? ' ▼' : ' ▲') : '';
    return '<th style="cursor:pointer" onclick="sortTasksBy(\'' + key + '\')">' + label + arrow + '</th>';
  }
  var h = '<table><thead><tr>' +
    th('task_id', 'ID') + th('task_status', 'Status') + th('task_target', 'Target') +
    th('project', 'Project') + th('detail', 'Description') + th('task_updated_at', 'Updated') +
    '</tr></thead><tbody>';
  taskState.filtered.forEach(function(t){
    var st = (t.task_status || 'pending').toLowerCase();
    var cls = st === 'completed' ? 'completed' : st === 'in-progress' ? 'in-progress' : st === 'failed' ? 'failed' : 'pending';
    h += '<tr><td><code>' + (t.task_id || t.event_id || '').substring(0,8) + '</code></td>';
    h += '<td><span class="badge ' + cls + '">' + st + '</span></td>';
    h += '<td>' + (t.task_target || '-') + '</td><td>' + (t.project || '-') + '</td>';
    h += '<td>' + (t.detail || '').substring(0,80) + '</td>';
    h += '<td>' + (t.task_updated_at || '').substring(0,16) + '</td></tr>';
  });
  h += '</tbody></table>';
  el.innerHTML = h;
}

function sortTasksBy(key) {
  if (taskState.sortKey === key) { taskState.sortDesc = !taskState.sortDesc; }
  else { taskState.sortKey = key; taskState.sortDesc = true; }
  applyTaskFilters();
}

function clearTaskFilters() {
  taskState.search = ""; taskState.statusFilter = ""; taskState.targetFilter = ""; taskState.projectFilter = "";
  document.getElementById('taskSearch').value = "";
  document.getElementById('taskStatusFilter').value = "";
  document.getElementById('taskTargetFilter').value = "";
  document.getElementById('taskProjectFilter').value = "";
  applyTaskFilters();
}

var searchDebounce = null;
document.getElementById('taskSearch').addEventListener('input', function(e){
  clearTimeout(searchDebounce);
  searchDebounce = setTimeout(function(){ taskState.search = e.target.value; applyTaskFilters(); }, 150);
});
document.getElementById('taskStatusFilter').addEventListener('change', function(e){ taskState.statusFilter = e.target.value; applyTaskFilters(); });
document.getElementById('taskTargetFilter').addEventListener('change', function(e){ taskState.targetFilter = e.target.value; applyTaskFilters(); });
document.getElementById('taskProjectFilter').addEventListener('change', function(e){ taskState.projectFilter = e.target.value; applyTaskFilters(); });
```

