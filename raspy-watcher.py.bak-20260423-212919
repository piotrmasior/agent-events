#!/usr/bin/env python3
"""Raspy event watcher v4 — triggers agent turn in Slack session.

On new event:
1. Find the Slack #raspy_with_me session ID
2. Run `openclaw agent --session-id <id> --message "..." --deliver`
   This triggers a full agent turn with tools in the Slack session context.
"""

import json
import os
import subprocess
import sys
import time
import signal
import re
from datetime import datetime, timezone
from pathlib import Path

sys.stdout.reconfigure(line_buffering=True)
sys.stderr.reconfigure(line_buffering=True)

BASE_DIR = Path(os.environ.get("EVENTBUS_DIR", Path.home() / "agent-events"))
EVENTS_DIR = BASE_DIR / "events"
WATCH_DIRS = [
    EVENTS_DIR / "agent" / "raspy",
    EVENTS_DIR / "agent" / "claude-code",
]
HEARTBEAT_FILE = BASE_DIR / ".raspy-watcher-heartbeat"
STATE_FILE = BASE_DIR / ".raspy-watcher-state"
PID_FILE = BASE_DIR / ".raspy-watcher.pid"
DEFAULT_CHECK_INTERVAL = 30

SLACK_CHANNEL_KEY = "c0adeu0060h"  # #raspy_with_me
OPENCLAW_BIN = "/home/pmasior/.npm-global/bin/openclaw"
SESSIONS_FILE = Path.home() / ".openclaw/agents/main/sessions/sessions.json"
_cached_session_id = None


def get_slack_session_id():
    """Find the Slack session ID for #raspy_with_me."""
    global _cached_session_id
    if _cached_session_id:
        return _cached_session_id
    
    # Method 1: parse openclaw sessions output
    try:
        r = subprocess.run(
            [OPENCLAW_BIN, "sessions", "--json"],
            capture_output=True, text=True, timeout=15
        )
        if r.returncode == 0:
            data = json.loads(r.stdout)
            for s in (data if isinstance(data, list) else data.get("sessions", [])):
                key = s.get("key", s.get("sessionKey", ""))
                if SLACK_CHANNEL_KEY in key.lower() and "thread" not in key.lower():
                    sid = s.get("id", s.get("sessionId", ""))
                    if sid:
                        _cached_session_id = sid
                        print(f"[watcher] Slack session ID: {sid}")
                        return sid
    except Exception as e:
        print(f"[watcher] sessions --json failed: {e}", file=sys.stderr)

    # Method 2: parse sessions file directly
    try:
        data = json.loads(SESSIONS_FILE.read_text())
        for key in data:
            if SLACK_CHANNEL_KEY in key.lower() and "thread" not in key.lower():
                entry = data[key]
                if isinstance(entry, dict):
                    sid = entry.get("id", entry.get("sessionId", ""))
                    if sid:
                        _cached_session_id = sid
                        print(f"[watcher] Slack session ID (file): {sid}")
                        return sid
    except Exception as e:
        print(f"[watcher] sessions file parse failed: {e}", file=sys.stderr)

    print("[watcher] Could not find Slack session ID", file=sys.stderr)
    return None


def write_heartbeat():
    HEARTBEAT_FILE.write_text(datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"))

def write_pid():
    PID_FILE.write_text(str(os.getpid()))

def load_state():
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return {"notified_ids": {}}

def save_state(state):
    tmp = STATE_FILE.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, indent=2))
    tmp.rename(STATE_FILE)

def parse_event_file(path):
    try:
        content = Path(path).read_text()
        parts = content.split("---\n", 2)
        if len(parts) < 3:
            return None
        meta = {}
        for line in parts[1].strip().splitlines():
            if ": " in line:
                key, value = line.split(": ", 1)
                key = key.strip()
                if key == "acknowledged":
                    meta[key] = value.strip().lower() == "true"
                elif key in ("id", "topic", "source_machine", "source_agent"):
                    meta[key] = value.strip()
        body = parts[2].strip()
        if "\n## Log" in body:
            body = body[:body.index("\n## Log")].strip()
        meta["body"] = body
        meta["file_path"] = str(path)
        return meta
    except Exception:
        return None


def trigger_agent(event_id, topic, body, source=""):
    """Trigger a full agent turn in the Slack session with event details."""
    session_id = get_slack_session_id()
    if not session_id:
        print(f"[watcher] No session ID — falling back to system event for {event_id}", file=sys.stderr)
        return fallback_system_event(event_id, body)

    msg = (
        f"[event-bus task {event_id}] from {source} on {topic}:\n"
        f"{body}\n\n"
        f"Execute this task. When done, FIRST enrich with your answer: ~/agent-events/eventbus.sh enrich {event_id} '<answer>' — THEN ack: ~/agent-events/eventbus.sh ack {event_id}. The enrich step is mandatory — it is how the delegator receives your answer cross-machine."
    )
    try:
        r = subprocess.run(
            [OPENCLAW_BIN, "agent",
             "--session-id", session_id,
             "--message", msg,
             "--deliver", "--reply-channel", "slack", "--reply-to", "C0ADEU0060H",
             "--timeout", "120"],
            capture_output=True, text=True, timeout=150
        )
        if r.returncode == 0:
            print(f"[watcher] Agent turn completed for event {event_id}")
            return True
        else:
            print(f"[watcher] Agent turn failed (rc={r.returncode}): {r.stderr.strip()[:200]}", file=sys.stderr)
            # Session ID might be stale — clear cache
            global _cached_session_id
            _cached_session_id = None
    except subprocess.TimeoutExpired:
        print(f"[watcher] Agent turn timeout for {event_id}", file=sys.stderr)
    except Exception as e:
        print(f"[watcher] Agent turn error: {e}", file=sys.stderr)

    return fallback_system_event(event_id, body)


def fallback_system_event(event_id, body):
    """Fallback if agent turn fails."""
    text = f"[event-watcher] Process event {event_id}: {body[:200]}"
    try:
        r = subprocess.run(
            [OPENCLAW_BIN, "system", "event", "--mode", "now", "--text", text],
            capture_output=True, text=True, timeout=30
        )
        if r.returncode == 0:
            print(f"[watcher] Fallback system event sent for {event_id}")
            return True
    except Exception as e:
        print(f"[watcher] Fallback error: {e}", file=sys.stderr)
    return False


def scan_existing_unacknowledged(state):
    notified = 0
    for watch_dir in WATCH_DIRS:
        if not watch_dir.exists():
            continue
        for event_file in sorted(watch_dir.rglob("*.event")):
            meta = parse_event_file(event_file)
            if not meta:
                continue
            eid = meta.get("id", "")
            if not eid or eid in state.get("notified_ids", {}):
                continue
            if not meta.get("acknowledged", False):
                rel = str(Path(event_file).parent.relative_to(EVENTS_DIR))
                src = f"{meta.get('source_machine','')}/{meta.get('source_agent','')}"
                print(f"[watcher] Found existing unacknowledged event: {eid} on {rel}")
                if trigger_agent(eid, meta.get("topic", rel), meta.get("body", ""), src):
                    state.setdefault("notified_ids", {})[eid] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                    notified += 1
    return notified


def run_inotify():
    for watch_dir in WATCH_DIRS:
        watch_dir.mkdir(parents=True, exist_ok=True)

    print(f"[watcher] Starting inotifywait on {[str(d) for d in WATCH_DIRS]} (recursive)")
    print(f"[watcher] PID: {os.getpid()}")
    print(f"[watcher] Wake method: openclaw agent --session-id (Slack session)")

    write_pid()
    state = load_state()

    # Pre-cache session ID
    get_slack_session_id()

    existing = scan_existing_unacknowledged(state)
    if existing:
        save_state(state)
        print(f"[watcher] Processed {existing} existing unacknowledged event(s)")

    running = True

    def handle_signal(signum, frame):
        nonlocal running
        print(f"\n[watcher] Shutting down (signal {signum})")
        save_state(state)
        running = False

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    inotify_args = ["inotifywait", "-r", "-m", "--format", "%w%f", "-e", "create", "-e", "moved_to"]
    for watch_dir in WATCH_DIRS:
        inotify_args.append(str(watch_dir))

    proc = subprocess.Popen(inotify_args, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    heartbeat_counter = 0

    try:
        while running and proc.poll() is None:
            try:
                import select
                ready, _, _ = select.select([proc.stdout], [], [], 5.0)
                if ready:
                    line = proc.stdout.readline()
                    if not line:
                        break
                    filepath = line.strip()
                    if not filepath.endswith(".event"):
                        continue
                    time.sleep(0.5)
                    meta = parse_event_file(filepath)
                    if not meta:
                        continue
                    eid = meta.get("id", "")
                    if not eid or eid in state.get("notified_ids", {}):
                        continue
                    if meta.get("acknowledged", False):
                        state.setdefault("notified_ids", {})[eid] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                        save_state(state)
                        continue
                    rel = str(Path(filepath).parent.relative_to(EVENTS_DIR))
                    src = f"{meta.get('source_machine','')}/{meta.get('source_agent','')}"
                    print(f"[watcher] New event: {eid} on {rel}")
                    if trigger_agent(eid, meta.get("topic", rel), meta.get("body", ""), src):
                        state.setdefault("notified_ids", {})[eid] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                        save_state(state)
            except Exception as e:
                print(f"[watcher] Error in watch loop: {e}", file=sys.stderr)

            heartbeat_counter += 1
            if heartbeat_counter >= 6:
                write_heartbeat()
                heartbeat_counter = 0
                cutoff = (datetime.now(timezone.utc) - __import__("datetime").timedelta(hours=24)).strftime("%Y-%m-%dT%H:%M:%SZ")
                state["notified_ids"] = {k: v for k, v in state.get("notified_ids", {}).items() if v > cutoff}
                save_state(state)

    finally:
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                proc.kill()
        write_heartbeat()

    print("[watcher] Stopped.")


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description="Raspy event watcher daemon")
    parser.add_argument("--check-interval", type=int, default=DEFAULT_CHECK_INTERVAL)
    args = parser.parse_args()
    run_inotify()
