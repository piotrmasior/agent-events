#!/usr/bin/env python3
"""Raspy event watcher — monitors agent/raspy topic for new events and wakes OpenClaw.

Uses inotifywait to watch ~/agent-events/events/agent/raspy/ for new .event files.
When a new unacknowledged event appears, triggers OpenClaw heartbeat immediately
(via `openclaw system event --mode now`) so Raspy can respond quickly.

Also watches agent/raspy/# (recursive) for any sub-topics.

Usage: python3 raspy-watcher.py [--check-interval 30]
"""

import json
import os
import subprocess
import sys
import time
import signal
from datetime import datetime, timezone
from pathlib import Path

# Force unbuffered stdout
sys.stdout.reconfigure(line_buffering=True)
sys.stderr.reconfigure(line_buffering=True)

BASE_DIR = Path(os.environ.get("EVENTBUS_DIR", Path.home() / "agent-events"))
EVENTS_DIR = BASE_DIR / "events"
WATCH_DIRS = [
    EVENTS_DIR / "agent" / "raspy",
    EVENTS_DIR / "agent" / "claude-code",
]
HEARTBEAT_FILE = BASE_DIR / ".raspy-watcher-heartbeat"
STATE_FILE = BASE_DIR / ".raspy-watcher-state"
PID_FILE = BASE_DIR / ".raspy-watcher.pid"
DEFAULT_CHECK_INTERVAL = 30  # fallback poll if inotify dies


def write_heartbeat():
    ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    HEARTBEAT_FILE.write_text(ts)


def write_pid():
    PID_FILE.write_text(str(os.getpid()))


def load_state():
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return {"notified_ids": {}}


def save_state(state):
    tmp = STATE_FILE.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, indent=2))
    tmp.rename(STATE_FILE)


def parse_event_frontmatter(path):
    """Quick parse — just get id and acknowledged from frontmatter."""
    try:
        content = Path(path).read_text()
        parts = content.split("---\n", 2)
        if len(parts) < 3:
            return None
        meta = {}
        for line in parts[1].strip().splitlines():
            if ": " in line:
                key, value = line.split(": ", 1)
                key = key.strip()
                if key == "acknowledged":
                    meta[key] = value.strip().lower() == "true"
                elif key == "id":
                    meta[key] = value.strip()
        meta["file_path"] = str(path)
        return meta
    except Exception:
        return None


def wake_openclaw(event_id, topic):
    """Trigger OpenClaw heartbeat with event notification."""
    text = f"[event-watcher] New unacknowledged event on {topic}: {event_id}"
    try:
        result = subprocess.run(
            ["openclaw", "system", "event", "--mode", "now", "--text", text],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0:
            print(f"[watcher] Woke OpenClaw for event {event_id}")
        else:
            print(f"[watcher] Wake failed (rc={result.returncode}): {result.stderr.strip()}", file=sys.stderr)
        return result.returncode == 0
    except subprocess.TimeoutExpired:
        print(f"[watcher] Wake timeout for event {event_id}", file=sys.stderr)
        return False
    except Exception as e:
        print(f"[watcher] Wake error: {e}", file=sys.stderr)
        return False


def scan_existing_unacknowledged(state):
    """Scan for any existing unacknowledged events we haven't notified about."""
    notified = 0
    for watch_dir in WATCH_DIRS:
        if not watch_dir.exists():
            continue
        for event_file in sorted(watch_dir.rglob("*.event")):
            meta = parse_event_frontmatter(event_file)
            if not meta:
                continue
            eid = meta.get("id", "")
            if not eid or eid in state.get("notified_ids", {}):
                continue
            if not meta.get("acknowledged", False):
                rel = str(Path(event_file).parent.relative_to(EVENTS_DIR))
                print(f"[watcher] Found existing unacknowledged event: {eid} on {rel}")
                if wake_openclaw(eid, rel):
                    state.setdefault("notified_ids", {})[eid] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                    notified += 1
    return notified


def run_inotify():
    """Run inotifywait monitoring watched topic dirs."""
    # Ensure watch dirs exist
    for watch_dir in WATCH_DIRS:
        watch_dir.mkdir(parents=True, exist_ok=True)

    print(f"[watcher] Starting inotifywait on {[str(d) for d in WATCH_DIRS]} (recursive)")
    print(f"[watcher] PID: {os.getpid()}")

    write_pid()

    state = load_state()

    # First, scan for any existing unacknowledged events
    existing = scan_existing_unacknowledged(state)
    if existing:
        save_state(state)
        print(f"[watcher] Notified about {existing} existing unacknowledged event(s)")

    running = True

    def handle_signal(signum, frame):
        nonlocal running
        print(f"\n[watcher] Shutting down (signal {signum})")
        save_state(state)
        running = False

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    # Start inotifywait in monitor mode — watch all dirs
    inotify_args = ["inotifywait", "-r", "-m", "--format", "%w%f", "-e", "create", "-e", "moved_to"]
    for watch_dir in WATCH_DIRS:
        inotify_args.append(str(watch_dir))

    proc = subprocess.Popen(
        inotify_args,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
    )

    heartbeat_counter = 0

    try:
        while running and proc.poll() is None:
            # Read with timeout so we can check signals
            try:
                # Use a simple read loop with line buffering
                import select
                ready, _, _ = select.select([proc.stdout], [], [], 5.0)
                if ready:
                    line = proc.stdout.readline()
                    if not line:
                        break
                    filepath = line.strip()
                    if not filepath.endswith(".event"):
                        continue

                    # Small delay to let file be fully written
                    time.sleep(0.5)

                    meta = parse_event_frontmatter(filepath)
                    if not meta:
                        continue

                    eid = meta.get("id", "")
                    if not eid:
                        continue

                    if eid in state.get("notified_ids", {}):
                        continue

                    if meta.get("acknowledged", False):
                        state.setdefault("notified_ids", {})[eid] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                        save_state(state)
                        continue

                    rel = str(Path(filepath).parent.relative_to(EVENTS_DIR))
                    print(f"[watcher] New event: {eid} on {rel}")
                    if wake_openclaw(eid, rel):
                        state.setdefault("notified_ids", {})[eid] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                        save_state(state)

            except Exception as e:
                print(f"[watcher] Error in watch loop: {e}", file=sys.stderr)

            heartbeat_counter += 1
            if heartbeat_counter >= 6:  # Every ~30s
                write_heartbeat()
                heartbeat_counter = 0

                # Prune old notified_ids (>24h)
                cutoff = (datetime.now(timezone.utc) - __import__("datetime").timedelta(hours=24)).strftime("%Y-%m-%dT%H:%M:%SZ")
                state["notified_ids"] = {
                    k: v for k, v in state.get("notified_ids", {}).items()
                    if v > cutoff
                }
                save_state(state)

    finally:
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                proc.kill()
        write_heartbeat()

    print("[watcher] Stopped.")


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description="Raspy event watcher daemon")
    parser.add_argument("--check-interval", type=int, default=DEFAULT_CHECK_INTERVAL,
                        help="Fallback poll interval in seconds (default: 30)")
    args = parser.parse_args()
    run_inotify()
